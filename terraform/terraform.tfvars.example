aws_region           = "eu-west-1"
environment          = "demo"
prefix               = "techstream"
ec2_instance_type    = "t3.small"
asg_min_size         = 1
asg_max_size         = 4
asg_desired_capacity = 1
enable_devops_guru   = true
alert_email          = "you@example.com"

# Required: your public IP for SSH access (never 0.0.0.0/0)
# Find yours: curl -s https://checkip.amazonaws.com
your_ip_cidr = "203.0.113.10/32"
